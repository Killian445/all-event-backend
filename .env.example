APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Base de données
# ---------------------------------------------------------------------------
# Local rapide : sqlite (fichier database/database.sqlite)
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Production (ex. Railway PostgreSQL) : décommenter et renseigner les variables Railway.
# DB_CONNECTION=pgsql
# DB_HOST=${PGHOST}
# DB_PORT=${PGPORT}
# DB_DATABASE=${PGDATABASE}
# DB_USERNAME=${PGUSER}
# DB_PASSWORD=${PGPASSWORD}

# ---------------------------------------------------------------------------
# Cache / session / queue
# ---------------------------------------------------------------------------
# Important : CACHE_STORE=database utilise la même connexion SQL que l’app.
# Si le driver PDO PostgreSQL n’est pas encore disponible au build ou au premier boot,
# des commandes comme "php artisan optimize" peuvent échouer (ex. delete from "cache").
# En production Railway, préférer "file" ou "redis" tant que la stack DB est stable.
CACHE_STORE=file
# CACHE_PREFIX=

# Session : "database" impose une connexion DB dès les routes web qui utilisent la session.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Les workers queue utilisent la DB ; l’API peut démarrer sans worker. Ajustez si besoin.
QUEUE_CONNECTION=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
BREVO_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Medias activites (upload fichier) : obligatoire pour que les images soient envoyees sur Cloudinary.
# Tableau de bord Cloudinary : https://console.cloudinary.com/
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Si erreur cURL 60 (SSL) en local sur Windows : preferer cacert.pem + curl.cainfo dans php.ini.
# Contournement dev uniquement (jamais en prod) : CLOUDINARY_HTTP_VERIFY=false
# CLOUDINARY_HTTP_VERIFY=false
